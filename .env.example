# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── MongoDB ───
MONGO_URI=mongodb://127.0.0.1:27017/blackrabbit

# ─── JWT ───
JWT_SECRET=change-me-to-a-strong-random-string-min-32-chars
JWT_EXPIRES_IN=8h

# ─── CORS ───
CORS_ORIGIN=http://localhost:5173

# ─── Cloudinary (image uploads) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Postgres (migration only) ───
PG_CONNECTION_STRING=postgresql://user:password@localhost:5432/blackrabbit

# ─── Web Push (VAPID) ───
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@blackrabbit.tn

# ─── Google Drive (image uploads) ───
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_USE_ADC=

